# Turso (libSQL)
TURSO_DATABASE_URL=libsql://your-company-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Better Auth (min 32 chars; generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-32-char-secret-here-replace-this

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_UPLOAD_BASE_URL=https://company.jaaryo.online

# AI providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
GEMINI_ANALYSIS_MODEL=gemini-3.5-flash
GEMINI_ENABLED=true
ANALYSIS_CONFIDENCE_THRESHOLD=0.6

# File storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Outbound email only
RESEND_API_KEY=re_xxx
EMAIL_FROM="SemuDesk <noreply@company.jaaryo.online>"

# Internal operator allowlist
JARYO_ADMIN_EMAILS=operator@example.com

# Optional integrations, to be added only after product/security review:
# - Open Banking / firm banking transaction import
# - card transaction import
# - Hometax data import or upload parsing
# - Vercel Cron worker secrets
